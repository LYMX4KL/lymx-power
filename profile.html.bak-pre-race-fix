<body>

<header class="nav">
  <div class="nav-inner">
    <a href="/" class="brand">LYMX <span id="rolePill" class="role-pill"></span></a>
    <nav class="nav-links">
      <a id="dashLink" href="/">Dashboard</a>
      <a href="/profile.html" class="on">Profile</a>
      <a href="/contacts.html">Contacts</a>
      <a href="#" id="signOut">Sign out</a>
    </nav>
    <div class="admin-avatar" id="userInitial">·</div>
  </div>
</header>

<main class="wrap">
  <h1>My Profile</h1>
  <div class="sub" id="welcomeSub">Complete your profile so we know how to reach you.</div>

  <div class="verification-banner" id="verifBanner" style="display:none"></div>

  <!-- 2026-05-20 #a461daa8 - Profile photo upload (5 MB, JPG/PNG/WEBP/GIF) -->
  <div class="card" style="text-align:center;padding:24px 20px">
    <div style="position:relative;display:inline-block">
      <div id="avatarRing" style="width:104px;height:104px;border-radius:50%;background:linear-gradient(135deg,#a01644,#6e0e2f);color:#fff;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:36px;overflow:hidden;border:3px solid #fff;box-shadow:0 6px 20px rgba(14,17,22,.18)">
        <span id="avatarInitials">·</span>
        <img id="avatarImg" alt="" style="width:100%;height:100%;object-fit:cover;display:none" />
      </div>
      <button type="button" id="avatarUploadBtn" aria-label="Upload profile photo"
              style="position:absolute;right:-2px;bottom:-2px;width:34px;height:34px;border-radius:50%;border:2px solid #fff;background:#0a84ff;color:#fff;cursor:pointer;font-size:16px;box-shadow:0 3px 10px rgba(10,132,255,.4);display:flex;align-items:center;justify-content:center">📷</button>
      <input id="avatarFile" type="file" accept="image/png,image/jpeg,image/webp,image/gif" style="display:none" />
    </div>
    <div style="margin-top:14px;font-size:13px;color:var(--muted)">
      <span id="avatarStatus">Tap the camera to upload a photo (max 5 MB)</span>
      <button type="button" id="avatarRemoveBtn" style="display:none;margin-left:12px;background:none;border:0;color:var(--danger,#e0413e);font-weight:700;cursor:pointer;font-size:13px;text-decoration:underline">Remove</button>
    </div>
  </div>

  <div class="card">
    <h2>About you</h2>

    <div class="row2">
      <div>
        <label>First name</label>
        <input id="firstName" type="text" />
      </div>
      <div>
        <label>Last name</label>
        <input id="lastName" type="text" />
      </div>
    </div>

    <label>Display name <span style="color:var(--muted);font-weight:600;text-transform:none;letter-spacing:0">(how you're shown to others)</span></label>
    <input id="displayName" type="text" />

    <label>Email</label>
    <input id="email" type="email" />
    <!-- 2026-05-19 #9e47a789 — email is now editable. On save, if it changed, we call supabase.auth.updateUser({email}) which sends a confirmation link to the new address. The change only takes effect after the user clicks that link. -->
    <div style="font-size:12px;color:var(--muted);margin-top:4px">Used for sign-in and digital receipts. Type a new email and click Save — we'll email a confirmation link to the new address before the change goes live.</div>

    <div class="row2">
      <div>
        <label>Phone <span style="color:var(--muted);font-weight:600;text-transform:none;letter-spacing:0">(optional)</span></label>
        <!-- 2026-05-19 #da338c58 — simpler placeholder; format depends on country selected -->
        <input id="phone" type="tel" placeholder="(555) 555-5555" />
      </div>
      <div>
        <label>Country</label>
        <select id="country">
          <option value="US">United States</option>
          <option value="CA">Canada</option>
          <option value="GB">United Kingdom</option>
          <option value="AU">Australia</option>
          <option value="DE">Germany</option>
          <option value="FR">France</option>
          <option value="MX">Mexico</option>
          <option value="BR">Brazil</option>
          <option value="JP">Japan</option>
          <option value="KR">South Korea</option>
          <option value="CN">China</option>
          <option value="TW">Taiwan</option>
          <option value="HK">Hong Kong</option>
          <option value="SG">Singapore</option>
          <option value="IN">India</option>
          <option value="PH">Philippines</option>
          <option value="OTHER">Other</option>
        </select>
      </div>
    </div>

    <div id="zipFieldWrap">
      <label id="zipLabel">ZIP code</label>
      <input id="zip" type="text" placeholder="89101" />
    </div>

    <div style="margin-top:14px">
      <label for="preferredLocale">Preferred language</label>
      <select id="preferredLocale">
        <option value="">— Auto-detect from browser —</option>
        <option value="en">English</option>
        <option value="es">Español (Spanish)</option>
        <option value="zh-CN">简体中文 (Simplified Chinese)</option>
        <option value="zh-TW">繁體中文 (Traditional Chinese)</option>
        <option value="ko">한국어 (Korean)</option>
        <option value="ja">日本語 (Japanese)</option>
      </select>
      <div style="font-size:12.5px;color:var(--muted);margin-top:4px">Used for the site interface and emails / SMS we send you.</div>
    </div>

    <div style="margin-top:22px;display:flex;gap:10px">
      <button class="btn btn-primary" id="saveBtn">Save changes</button>
      <a class="btn btn-ghost" id="dashLink2" href="/">Back to dashboard</a>
    </div>
  </div>

  <!-- 2026-05-20 #97508680 - partners look here for the video-call / booking-link setup. Surface team-calendar.html clearly for partners + businesses. Hidden for plain customers. -->
  <div class="card" id="calendarSetupCard" style="display:none">
    <h2>📅 Your booking calendar &amp; video room</h2>
    <p style="font-size:13.5px;color:var(--muted);margin:0 0 14px">Let clients book directly with you. Set your weekly availability, pick a handle for your public booking page (<code style="background:#f6f7f9;padding:1px 5px;border-radius:4px;font-size:12px">getlymx.com/c/yourname</code>), and every confirmed booking auto-creates a Daily.co video room you can share.</p>
    <div style="display:flex;gap:10px;flex-wrap:wrap">
      <a class="btn btn-primary" href="team-calendar.html">Set up my calendar →</a>
      <a class="btn btn-ghost" href="my-bookings.html">View my bookings</a>
    </div>
  </div>

  <div class="card" id="signupSrcCard" style="display:none">
    <h2>Signup details</h2>
    <div style="font-size:14px;color:var(--muted)" id="signupSrcText">—</div>
  </div>
</main>

<div class="toast" id="toast"></div>

<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<script src="lymx-config.js"></script>
<script src="lymx-auth.js"></script>
<script>
const SUPABASE_URL = window.LYMX_CONFIG && window.LYMX_CONFIG.SUPABASE_URL;
const ANON         = window.LYMX_CONFIG && window.LYMX_CONFIG.SUPABASE_ANON_KEY;

let myUser = null;
let myRole = null;     // 'partner' | 'customer' | 'business'
let myRow  = null;     // current row in partners/customers/businesses

async function authedFetch(path, opts = {}) {
  const s = window.LYMX && window.LYMX.getSession ? await window.LYMX.getSession() : null;
  const token = (s && s.access_token) || ANON;
  return fetch(SUPABASE_URL + path, {
    ...opts,
    headers: { 'apikey': ANON, 'Authorization': 'Bearer ' + token, 'Content-Type': 'application/json', ...(opts.headers || {}) }
  });
}

function esc(s) { return (s || '').toString().replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c])); }
function showToast(msg, kind) { const t = document.getElementById('toast'); t.textContent = msg; t.className = 'toast on ' + (kind || ''); setTimeout(() => t.className = 'toast', 3000); }

async function detectRole() {
  // Try partners first, then businesses, else customer
  const uid = myUser.id;
  const pr = await authedFetch('/rest/v1/partners?user_id=eq.' + uid + '&select=*&limit=1');
  if (pr.ok) {
    const arr = await pr.json();
    if (arr.length) return { role: 'partner', row: arr[0] };
  }
  const br = await authedFetch('/rest/v1/businesses?owner_user_id=eq.' + uid + '&select=*&limit=1');
  if (br.ok) {
    const arr = await br.json();
    if (arr.length) return { role: 'business', row: arr[0] };
  }
  // Default: customer (may need to upsert if no row exists)
  const cr = await authedFetch('/rest/v1/customers?user_id=eq.' + uid + '&select=*&limit=1');
  if (cr.ok) {
    const arr = await cr.json();
    if (arr.length) return { role: 'customer', row: arr[0] };
  }
  return { role: 'customer', row: null };
}

function fillForm() {
  // 2026-05-20 #20dafa0b - for orphaned users (auth.users exists but no row in
  // partners/customers/businesses) myRow is null and the old code bailed out,
  // leaving every field blank — including email. That looked like "email field
  // is missing." Now: still populate email from myUser.email even with no row,
  // so the form is usable on first save. Save flow already handles upsert.
  if (!myRow) {
    if (myUser && myUser.email) {
      const emailEl = document.getElementById('email');
      if (emailEl && !emailEl.value) emailEl.value = myUser.email;
    }
    return;
  }
  const r = myRow;
  if (myRole === 'partner') {
    const name = r.legal_name || '';
    const parts = name.split(/\s+/);
    document.getElementById('firstName').value = parts[0] || '';
    document.getElementById('lastName').value = parts.slice(1).join(' ');
    document.getElementById('displayName').value = r.display_name || '';
    document.getElementById('email').value = r.contact_email || myUser.email || '';
    document.getElementById('phone').value = r.contact_phone || '';
    document.getElementById('country').value = r.country_code || 'US';
    document.getElementById('zip').value = '';
  } else if (myRole === 'business') {
    document.getElementById('firstName').value = '';
    document.getElementById('lastName').value = '';
    document.getElementById('displayName').value = r.display_name || r.legal_name || '';
    document.getElementById('email').value = r.contact_email || myUser.email || '';
    document.getElementById('phone').value = r.phone || '';
    document.getElementById('country').value = r.country_code || 'US';
    document.getElementById('zip').value = r.zip || '';
  } else {
    // customer
    document.getElementById('firstName').value = '';
    document.getElementById('lastName').value = '';
    document.getElementById('displayName').value = r.display_name || '';
    document.getElementById('email').value = r.email || myUser.email || '';
    document.getElementById('phone').value = r.phone || '';
    document.getElementById('country').value = r.country_code || 'US';
    document.getElementById('zip').value = r.home_zip || '';
  }
  // Set the language picker from the row's preferred_locale (or empty for auto)
  const localePicker = document.getElementById('preferredLocale');
  if (localePicker) localePicker.value = (r && r.preferred_locale) || '';
  onCountryChange();
}

function onCountryChange() {
  const country = document.getElementById('country').value;
  const wrap = document.getElementById('zipFieldWrap');
  const label = document.getElementById('zipLabel');
  // 2026-05-20 #bdd94e6b - the partners table has no home_zip/zip column, so when a partner
  // typed a ZIP and saved, the value was silently dropped (looked like the save was broken).
  // Hide the ZIP field for partners entirely so they don't waste effort typing into a black hole.
  if (myRole === 'partner') {
    wrap.style.display = 'none';
    return;
  }
  if (country === 'US') {
    wrap.style.display = '';
    label.textContent = 'ZIP code';
    document.getElementById('zip').placeholder = '89101';
  } else if (country === 'OTHER') {
    wrap.style.display = 'none';
  } else {
    wrap.style.display = '';
    label.textContent = 'Postal code (optional)';
    document.getElementById('zip').placeholder = '';
  }
}

async function save() {
  const btn = document.getElementById('saveBtn');
  btn.disabled = true;
  btn.textContent = 'Saving…';

  const firstName = document.getElementById('firstName').value.trim();
  const lastName  = document.getElementById('lastName').value.trim();
  const display   = document.getElementById('displayName').value.trim();
  const phone     = document.getElementById('phone').value.trim() || null;
  const country   = document.getElementById('country').value;
  const zip       = document.getElementById('zip').value.trim() || null;
  const preferredLocale = document.getElementById('preferredLocale').value || null;
  const fullName  = (firstName + ' ' + lastName).trim();

  // Apply the locale change immediately to the active page (also persists to localStorage).
  if (preferredLocale && window.LymxI18n && window.LymxI18n.setLocale) {
    try { window.LymxI18n.setLocale(preferredLocale); } catch(e){}
  }

  let patch = {};
  let table = '';
  let key = '';
  let keyVal = '';

  if (myRole === 'partner') {
    table = 'partners';
    key = 'user_id'; keyVal = myUser.id;
    patch = {
      legal_name: fullName || display || (myRow && myRow.legal_name) || display,
      display_name: display || firstName,
      contact_phone: phone,
      country_code: country,
      preferred_locale: preferredLocale,
    };
  } else if (myRole === 'business') {
    table = 'businesses';
    key = 'owner_user_id'; keyVal = myUser.id;
    patch = {
      display_name: display,
      phone: phone,
      country_code: country,
      zip: country === 'US' ? zip : null,
      preferred_locale: preferredLocale,
    };
  } else {
    table = 'customers';
    key = 'user_id'; keyVal = myUser.id;
    // For customers we may need to upsert if no row exists.
    patch = {
      user_id: myUser.id,
      display_name: display || firstName,
      phone: phone,
      country_code: country,
      home_zip: country === 'US' ? zip : null,
      preferred_locale: preferredLocale,
      email: myUser.email,
    };
  }

  // 2026-05-20 #812b1f13 — was using raw POST without on_conflict, which made
  // PostgREST treat the call as a plain INSERT. For orphaned customers (auth
  // user exists but no customers row), the INSERT could 409 on a subsequent
  // save (after another flow created the row). Switching to supabase-js
  // upsert with onConflict matches the working pattern in customer-settings.html.
  let r;
  if (myRow) {
    // Update existing row
    r = await authedFetch('/rest/v1/' + table + '?' + key + '=eq.' + keyVal, {
      method: 'PATCH',
      headers: { 'Prefer': 'return=minimal' },
      body: JSON.stringify(patch),
    });
  } else {
    // Upsert via supabase-js (customer-only path; partners/businesses always
    // have a row created at signup so this branch is customers-only in practice)
    try {
      const sb = (window.LYMX && window.LYMX.sb) || (window.supabase && window.supabase.createClient && window.supabase.createClient(SUPABASE_URL, ANON));
      const { error: upsertErr } = await sb
        .from(table)
        .upsert(patch, { onConflict: key });
      r = { ok: !upsertErr, text: async () => upsertErr ? (upsertErr.message || String(upsertErr)) : '' };
    } catch (upsertEx) {
      r = { ok: false, text: async () => 'Upsert exception: ' + (upsertEx.message || String(upsertEx)) };
    }
  }

  // 2026-05-19 #9e47a789 — Email change flow. If the email input differs from
  // the current auth email, kick off Supabase's email-change confirmation.
  // Supabase sends a "confirm new email" link to the new address; the change
  // only takes effect once the user clicks it.
  var emailEl = document.getElementById('email');
  var newEmail = emailEl ? emailEl.value.trim() : '';
  var emailChangeNotice = '';
  if (newEmail && newEmail.toLowerCase() !== (myUser.email || '').toLowerCase()) {
    try {
      if (window.LYMX && window.LYMX.sb && window.LYMX.sb.auth) {
        var au = await window.LYMX.sb.auth.updateUser({ email: newEmail });
        if (au && au.error) {
          emailChangeNotice = ' (email change failed: ' + (au.error.message || 'unknown') + ')';
        } else {
          emailChangeNotice = ' — confirmation sent to ' + newEmail;
        }
      }
    } catch (e) {
      emailChangeNotice = ' (email change error: ' + (e.message || 'unknown') + ')';
    }
  }

  btn.disabled = false;
  btn.textContent = 'Save changes';
  if (!r.ok) {
    const t = await r.text();
    showToast('Save failed: ' + t.slice(0, 100), 'err');
    return;
  }
  showToast('Saved ✓' + emailChangeNotice, 'ok');
  // Refresh row in memory
  const det = await detectRole();
  myRow = det.row;
  renderHeader();
}

function renderHeader() {
  const init = ((myUser.email || 'L')[0] || 'L').toUpperCase();
  document.getElementById('userInitial').textContent = init;
  const pill = document.getElementById('rolePill');
  pill.textContent = myRole;
  pill.className = 'role-pill ' + myRole;

  // 2026-05-20 #97508680 - show calendar setup card for partners + businesses
  const calCard = document.getElementById('calendarSetupCard');
  if (calCard) calCard.style.display = (myRole === 'partner' || myRole === 'business') ? '' : 'none';

  const dashHref = myRole === 'partner' ? '/rep-dashboard.html'
                 : myRole === 'business' ? '/biz-dashboard.html'
                 : '/customer-dashboard.html';
  document.getElementById('dashLink').href = dashHref;
  document.getElementById('dashLink2').href = dashHref;

  // Verification banner
  const verified = myRow && myRow.verified_at;
  const banner = document.getElementById('verifBanner');
  if (myRole === 'business') {
    // Businesses go through their own intake flow; don't show banner
    banner.style.display = 'none';
  } else if (verified) {
    banner.className = 'verification-banner verified';
    banner.innerHTML = '<strong>✓ Verified.</strong> You can ' + (myRole === 'partner' ? 'receive commission payouts' : 'spend your LYMX at any partner business') + '.';
    banner.style.display = '';
  } else {
    // 2026-05-20 #2f5bc26b - Rae's "What does this mean?" - the explanation was already inline but easy to miss. Now: clearer line breaks, bulleted what-you-can-do-now / what-changes-after, plus an explicit "What is verification?" tooltip.
    banner.className = 'verification-banner unverified';
    const holdLabel = myRole === 'partner' ? 'commission payouts' : 'LYMX spending at businesses';
    banner.innerHTML =
      '<div style="display:flex;gap:10px;align-items:flex-start">'
