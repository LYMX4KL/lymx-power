// 2026-05-20 #a461daa8 — Profile avatar render + upload + remove.
// Storage layout: avatars/<user_id>/<timestamp>.<ext>
// Public reads, owner-only writes (see migration 064).
function paintAvatar(url) {
  const img = document.getElementById('avatarImg');
  const ini = document.getElementById('avatarInitials');
  const rm  = document.getElementById('avatarRemoveBtn');
  if (!img || !ini || !rm) return;
  const fn = (document.getElementById('firstName') || {}).value || '';
  const ln = (document.getElementById('lastName')  || {}).value || '';
  const dn = (document.getElementById('displayName') || {}).value || '';
  const em = (myUser && myUser.email) || '';
  const parts = (dn || (fn + ' ' + ln) || em).split(/[\s@]+/).filter(Boolean);
  ini.textContent = (parts.slice(0,2).map(p => (p[0] || '').toUpperCase()).join('')) || '·';
  if (url) {
    img.src = url + (url.indexOf('?') === -1 ? '?t=' + Date.now() : '');
    img.style.display = 'block';
    ini.style.display = 'none';
    rm.style.display  = 'inline-block';
    // 2026-05-20 #a461daa8 - if the image fails (deleted / network), fall
    // back to initials instead of showing a broken-image icon.
    img.onerror = function () {
      img.style.display = 'none';
      ini.style.display = 'inline';
      rm.style.display  = 'none';
      var status = document.getElementById('avatarStatus');
      if (status) status.textContent = 'Could not load photo. Re-upload to fix.';
    };
  } else {
    img.style.display = 'none';
    ini.style.display = 'inline';
    rm.style.display  = 'none';
  }
}

async function uploadAvatar(file) {
  if (!file) return;
  const status = document.getElementById('avatarStatus');
  if (file.size > 5 * 1024 * 1024) {
    if (status) status.textContent = 'File too large — max 5 MB.';
    return;
  }
  if (!/^image\/(png|jpe?g|webp|gif)$/i.test(file.type)) {
    if (status) status.textContent = 'Only PNG, JPG, WEBP, GIF allowed.';
    return;
  }
  const sb = window.LYMX && window.LYMX.sb;
  if (!sb) { if (status) status.textContent = 'Still loading — try again in a second.'; return; }
  const uid = myUser && myUser.id;
  if (!uid) { if (status) status.textContent = 'Sign in first.'; return; }
  if (status) status.textContent = 'Uploading…';
  try {
    const ext = (file.name.match(/\.([a-z0-9]+)$/i) || [, 'jpg'])[1].toLowerCase();
    const path = uid + '/' + Date.now() + '.' + ext;
    const { error: upErr } = await sb.storage.from('avatars').upload(path, file, {
      cacheControl: '3600', upsert: true, contentType: file.type
    });
    if (upErr) throw upErr;
    const { data: pub } = sb.storage.from('avatars').getPublicUrl(path);
    const url = pub && pub.publicUrl;
    if (!url) throw new Error('Could not resolve public URL');
    // 2026-05-21 #aebedf90 — write the new avatar_url to EVERY table that has
    // a row for this user_id (partners + customers). Pre-fix, we only wrote to
    // the table matching myRole. A customer who uploaded an avatar, then later
    // upgraded to partner, ended up with customers.avatar_url set but
    // partners.avatar_url null — so the avatar "disappeared" once
    // detectRole() returned 'partner' on subsequent loads. Now: blanket
    // multi-table save keeps every existing row in sync.
    let saveErr;
    // Always update partners row if it exists for this user
    {
      const { data: pRow } = await sb.from('partners').select('id').eq('user_id', uid).maybeSingle();
      if (pRow && pRow.id) {
        const { error } = await sb.from('partners').update({ avatar_url: url }).eq('id', pRow.id);
        if (error) saveErr = error;
      }
    }
    // Always update customers row if it exists for this user; upsert if missing
    {
      const { data: cRow } = await sb.from('customers').select('id').eq('user_id', uid).maybeSingle();
      if (cRow && cRow.id) {
        const { error } = await sb.from('customers').update({ avatar_url: url }).eq('id', cRow.id);
        if (error) saveErr = error;
      } else {
        const { error } = await sb.from('customers').upsert(
          { user_id: uid, email: myUser.email, avatar_url: url },
          { onConflict: 'user_id' }
        );
        if (error) saveErr = error;
      }
    }
    if (saveErr) throw saveErr;
    // 2026-05-20 #a461daa8 - delete the OLD storage object (if any) so the
    // bucket doesn't accumulate orphans every time a user re-uploads.
    var prevUrl = myRow && myRow.avatar_url;
    if (prevUrl) {
      var prevPath = avatarUrlToPath(prevUrl);
      if (prevPath && prevPath !== path) {
        try {
          var del = await sb.storage.from('avatars').remove([prevPath]);
          if (del && del.error) console.warn('[avatar upload] could not remove previous file', del.error);
        } catch (e) { console.warn('[avatar upload] previous-file delete threw', e); }
      }
    }
    if (myRow) myRow.avatar_url = url;
    paintAvatar(url);
    // 2026-05-20 #27ca3ff2 — purge the lymx-nav.js sessionStorage cache so the
    // sidebar avatar / top-right chip update on the NEXT page navigation
    // without waiting for session end.
    try {
      if (myUser && myUser.id) {
        sessionStorage.setItem('LYMX_avatar_url_' + myUser.id, url);
      }
    } catch (e) { console.warn('[avatar upload] cache update', e); }
    if (status) status.textContent = 'Photo updated.';
  } catch (e) {
    console.warn('[avatar upload] failed', e);
    if (status) status.textContent = 'Upload failed: ' + (e && e.message ? e.message : 'unknown error');
  }
}

// 2026-05-20 #a461daa8 - Parse a Supabase public URL back into its bucket path.
// Format: https://<project>.supabase.co/storage/v1/object/public/avatars/<path>
// Also strips any ?t= cache-buster suffix we may have appended.
function avatarUrlToPath(url) {
  if (!url) return null;
  try {
    var m = String(url).match(/\/storage\/v1\/object\/public\/avatars\/([^?#]+)/i);
    return m ? decodeURIComponent(m[1]) : null;
  } catch (e) { console.warn('[avatar] url parse failed', e); return null; }
}

async function removeAvatar() {
  const sb = window.LYMX && window.LYMX.sb;
  if (!sb || !myUser) return;
  if (!confirm('Remove your profile photo?')) return;
  const status = document.getElementById('avatarStatus');
  try {
    // Capture old URL BEFORE we null the DB row, so we can clean up storage.
    var prevUrl = myRow && myRow.avatar_url;
    // 2026-05-21 #aebedf90 — mirror upload-side multi-table write: null the
    // avatar_url in every table that has a row for this user_id, so removal
    // is consistent regardless of myRole.
    const uid = myUser && myUser.id;
    if (uid) {
      const { data: pRow } = await sb.from('partners').select('id').eq('user_id', uid).maybeSingle();
      if (pRow && pRow.id) {
        const { error } = await sb.from('partners').update({ avatar_url: null }).eq('id', pRow.id);
        if (error) throw error;
      }
      const { data: cRow } = await sb.from('customers').select('id').eq('user_id', uid).maybeSingle();
      if (cRow && cRow.id) {
        const { error } = await sb.from('customers').update({ avatar_url: null }).eq('id', cRow.id);
        if (error) throw error;
      }
    }
    // 2026-05-20 #a461daa8 - actually delete the storage object too.
    if (prevUrl) {
      var prevPath = avatarUrlToPath(prevUrl);
      if (prevPath) {
        try {
          var del = await sb.storage.from('avatars').remove([prevPath]);
          if (del && del.error) console.warn('[avatar remove] storage delete error', del.error);
        } catch (e) { console.warn('[avatar remove] storage delete threw', e); }
      }
    }
    if (myRow) myRow.avatar_url = null;
    paintAvatar(null);
    // 2026-05-20 #a461daa8 - bust the sessionStorage cache in lymx-nav.js so
    // subsequent paints don't re-show the deleted photo from cache.
    try {
      if (myUser && myUser.id) sessionStorage.removeItem('LYMX_avatar_url_' + myUser.id);
    } catch (e) { console.warn('[avatar remove] sessionStorage purge', e); }
    if (status) status.textContent = 'Photo removed.';
  } catch (e) {
    console.warn('[avatar remove] failed', e);
    if (status) status.textContent = 'Remove failed: ' + (e && e.message ? e.message : 'unknown error');
  }
}

(function wireAvatarUi() {
  const btn = document.getElementById('avatarUploadBtn');
  const fi  = document.getElementById('avatarFile');
  const rm  = document.getElementById('avatarRemoveBtn');
  if (btn && fi) btn.addEventListener('click', function () { fi.click(); });
  if (fi) fi.addEventListener('change', function (e) {
    const f = e.target.files && e.target.files[0];
    if (f) uploadAvatar(f);
    e.target.value = '';
  });
  if (rm) rm.addEventListener('click', removeAvatar);
})();

(async function init() {
  const s = window.LYMX && window.LYMX.getSession ? await window.LYMX.getSession() : null;
  if (!s) { location.href = '/login.html?next=/profile.html'; return; }
  myUser = s.user;
  const det = await detectRole();
  myRole = det.role;
  myRow  = det.row;
  renderHeader();
  fillForm();
  paintAvatar(myRow && myRow.avatar_url);
})();
</script>

