# Netlify redirects for LYMX Power.
# Format: <from-path> <to-path> <status>
# 301 = permanent redirect (preserves SEO + browser history).
# Wildcards: * matches any segment.

# Partner email template uses "/partners/dashboard" but the actual page is rep-dashboard.html
/partners/dashboard          /rep-dashboard.html              301
/partners                    /rep-dashboard.html              301
/partner                     /partner-signup.html             301

# Pretty URLs without .html extension (so /browse works as well as /browse.html)
/login                       /login.html                      301
/browse                      /browse.html                      301
/business                    /business.html                    301
/about                       /about.html                       301
/customer-signup             /customer-signup.html             301
/biz-signup                  /biz-signup.html                  301
/partner-signup              /partner-signup.html              301
/customer-dashboard          /customer-dashboard.html          301
/biz-dashboard               /biz-dashboard.html               301
/rep-dashboard               /rep-dashboard.html               301
/customer-wallet             /customer-wallet.html             301
/admin-dashboard             /admin-dashboard.html             301
/write-review                /write-review.html                301

# 2026-05-27 — biz storefront templating (T1 root-cause architectural fix).
# Replaced per-biz hand-coded HTML (biz-oakline-kitchen.html + biz-brew-and-
# bean.html) with a single templated biz.html that reads ?slug=<slug> and
# renders from public.businesses via fn_biz_public_meta. The old direct-file
# URLs redirect into the templated page so existing inbound links + /browse
# cards + search results + bookmarks keep working.
/biz                         /biz.html                         301

# Suffix-less paths (browse cards + most internal links)
/biz-oakline-kitchen         /biz.html?slug=oakline-kitchen    301
/biz-brew-and-bean           /biz.html?slug=brew-and-bean      301

# .html-suffix paths (external bookmarks + deep links)
/biz-oakline-kitchen.html    /biz.html?slug=oakline-kitchen    301
/biz-brew-and-bean.html      /biz.html?slug=brew-and-bean      301

# Forward-looking generic route: every future approved business auto-has a
# public URL the moment their slug is set. /biz/<slug> → biz.html template.
# No per-biz HTML coding from the team is needed.
/biz/:slug                   /biz.html?slug=:slug              200
